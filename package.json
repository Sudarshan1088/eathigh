{
  "name": "eathigh",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm -w @eathigh/api run dev",
    "dev:web": "npm -w @eathigh/web run dev",
    "build": "npm -w @eathigh/web run build",
    "typecheck": "npm -w @eathigh/shared run typecheck && npm -w @eathigh/api run typecheck && npm -w @eathigh/web run typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.2.3"
  }
}
